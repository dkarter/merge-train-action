{
  "name": "merge-train-action",
  "version": "0.1.0",
  "description": "Reusable GitHub Action for merge-train orchestration.",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "package": "npm run build && ncc build src/main.ts -o dist --source-map --license licenses.txt",
    "ci": "npm run lint && npm run format:check && npm run test && npm run package"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "github-action",
    "merge-train",
    "pull-request"
  ],
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.11.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.30",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0",
    "@vercel/ncc": "^0.38.3",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.1",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
